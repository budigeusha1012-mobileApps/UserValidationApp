<?xml version="1.0" encoding="utf-8"?>

<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/formFragment">

    <fragment
        android:id="@+id/formFragment"
        android:name="com.example.myvalidationapp.presentation.FormFragment"
        android:label="FormFragment">

        <action
            android:id="@+id/action_formFragment_to_successFragment"
            app:destination="@id/successFragment"/>

    </fragment>

    <fragment
        android:id="@+id/successFragment"
        android:name="com.example.myvalidationapp.presentation.SuccessFragment"
        android:label="SuccessFragment">
        <action
            android:id="@+id/action_successFragment_to_formFragment"
            app:destination="@id/formFragment"/>

    </fragment>


</navigation>